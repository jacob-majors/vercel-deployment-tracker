{
  "name": "deplog-menubar",
  "version": "0.1.0",
  "private": true,
  "description": "Mac menu bar monitor for Vercel deployments and GitHub Actions.",
  "main": "dist-electron/main.js",
  "author": "Jacob Majors",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsup electron/main.ts electron/preload.ts --format cjs --out-dir dist-electron --splitting false --external electron --watch",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/main.js && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsup electron/main.ts electron/preload.ts --format cjs --out-dir dist-electron --splitting false --external electron --clean",
    "dist:mac": "npm run build && electron-builder --mac",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.jacobmajors.deplogmenubar",
    "productName": "Deplog Menu Bar",
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^39.8.9",
    "electron-builder": "^26.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
}
